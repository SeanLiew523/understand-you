{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ActiveBets",
  "type": "object",
  "required": [
    "bets"
  ],
  "properties": {
    "bets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/bet"
      }
    }
  },
  "definitions": {
    "bet": {
      "type": "object",
      "required": [
        "label",
        "status"
      ],
      "properties": {
        "label": {
          "type": "string",
          "description": "Short name of the bet or priority area"
        },
        "priority": {
          "type": "string",
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ],
          "default": "medium"
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "paused",
            "completed",
            "dropped"
          ]
        },
        "added_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
