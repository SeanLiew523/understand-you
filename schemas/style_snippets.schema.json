{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StyleSnippets",
  "type": "object",
  "properties": {
    "likes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dislikes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "snippet"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}