{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FeedbackEvent",
  "type": "object",
  "required": [
    "timestamp",
    "source",
    "score",
    "issue_type",
    "confidence"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "string",
      "enum": [
        "direct_user_feedback",
        "ab_test_choice",
        "behavioral_inference",
        "manual_review"
      ]
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 10
    },
    "issue_type": {
      "type": "string",
      "enum": [
        "too_verbose",
        "too_vague",
        "weak_evidence",
        "weak_reasoning",
        "wrong_tone",
        "too_intrusive",
        "boundary_miss",
        "wrong_tool_choice",
        "good_fit",
        "other"
      ]
    },
    "free_text": {
      "type": [
        "string",
        "null"
      ]
    },
    "recommended_target_file": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "USER.md",
        "MEMORY.md",
        "IDENTITY.md",
        "AGENTS.md",
        "TOOLS.md",
        "HEARTBEAT.md",
        "SOUL.md",
        null
      ]
    },
    "recommended_target_section": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  },
  "additionalProperties": false
}
